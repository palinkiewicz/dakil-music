<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Audio access: granular media permission on API 33+, legacy storage below it. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Background playback as a media foreground service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Now Playing notification on API 33+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Fetching lyrics from the lrclib.net API. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Controlling the equalizer / bass boost / virtualizer audio effects. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:name=".MusicApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Music">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Music">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Voice "play …" requests from Android Auto / Google Assistant. -->
            <intent-filter>
                <action android:name="android.media.action.MEDIA_PLAY_FROM_SEARCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Chooser entry for externally opened audio files: appends the file to the
             live play queue. An alias so the option gets its own label while routing
             into MainActivity's existing singleTop intent handling. -->
        <activity-alias
            android:name=".AddToQueueActivity"
            android:exported="true"
            android:label="@string/chooser_add_to_queue"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="audio/*" />
                <data android:scheme="file" android:mimeType="audio/*" />
            </intent-filter>
        </activity-alias>

        <!-- Chooser entry for externally opened audio files: transient standalone player.
             Only the VIEW filter, so it is unreachable from the launcher or in-app
             navigation; empty taskAffinity + excludeFromRecents keep it inside the
             caller's task, like a viewer rather than a second app instance. -->
        <activity
            android:name=".presentation.quickplayer.QuickPlayerActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:label="@string/chooser_quick_player"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/Theme.Music">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="audio/*" />
                <data android:scheme="file" android:mimeType="audio/*" />
            </intent-filter>
        </activity>

        <!-- Media3 playback engine: hosts the ExoPlayer + MediaLibrarySession so playback,
             the system Now Playing notification and lock-screen controls survive
             outside the Activity lifecycle, and so media browsers (Android Auto) can
             browse the library. The legacy MediaBrowserService action lets Android Auto
             discover the app. -->
        <service
            android:name=".data.playback.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaLibraryService" />
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>

        <!-- Declares this app as an Android Auto media app. -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <!-- Home-screen widget: current track, cover art and transport controls. -->
        <receiver
            android:name=".widget.MusicWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/music_widget_info" />
        </receiver>

    </application>

</manifest>
