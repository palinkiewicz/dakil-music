<?xml version="1.0" encoding="utf-8"?>
<!-- Static preview shown in the launcher's widget picker (not used at runtime). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="#33808080"
        android:padding="14dp"
        android:src="@drawable/ic_widget_music_note"
        android:contentDescription="@null"
        android:tint="?android:attr/textColorPrimary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/widget_label"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="6dp"
            android:src="@drawable/ic_widget_play"
            android:contentDescription="@null"
            android:tint="?android:attr/textColorPrimary" />
    </LinearLayout>

</LinearLayout>
